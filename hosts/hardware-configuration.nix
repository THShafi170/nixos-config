# Do not modify this file!  It was generated by 'nixos-generate-config'
# and may be overwritten by future invocations.  Please make changes
# to /etc/nixos/configuration.nix instead.
{
  config,
  lib,
  modulesPath,
  ...
}:

let
  rootUUID = "73508ce6-9a32-4819-9335-ae49af24622d";

  btrfsCommon = [
    "noatime"
    "compress=zstd:3"
    "ssd"
    "discard=async"
    "space_cache=v2"
    "commit=120"
  ];

  mkBtrfsSubvol = subvol: {
    device = "/dev/disk/by-uuid/${rootUUID}";
    fsType = "btrfs";
    options = [ "subvol=${subvol}" ] ++ btrfsCommon;
  };
in
{
  imports = [
    (modulesPath + "/installer/scan/not-detected.nix")
  ];

  boot.initrd.availableKernelModules = [
    "xhci_pci"
    "nvme"
    "usb_storage"
    "sd_mod"
    "rtsx_pci_sdmmc"
  ];
  boot.initrd.kernelModules = [ ];
  boot.kernelModules = [ "kvm-intel" ];
  boot.extraModulePackages = [ ];

  fileSystems = {
    "/"                  = mkBtrfsSubvol "@";
    "/nix"               = mkBtrfsSubvol "@nix";
    "/root"              = mkBtrfsSubvol "@root";
    "/srv"               = mkBtrfsSubvol "@srv";
    "/swap"              = mkBtrfsSubvol "@swap";
    "/var/cache"         = mkBtrfsSubvol "@cache";
    "/var/lib/machines"  = mkBtrfsSubvol "@machines";
    "/var/lib/portables" = mkBtrfsSubvol "@portables";
    "/var/log"           = mkBtrfsSubvol "@log";
    "/var/tmp"           = mkBtrfsSubvol "@tmp";

    "/home" = {
      device = "/dev/disk/by-uuid/55be77ee-1dae-4971-96b0-5bfa120d7a4f";
      fsType = "btrfs";
      options = btrfsCommon;
    };

    "/media/extra" = {
      device = "/dev/disk/by-uuid/ae4ce961-59c0-4e37-a453-04ba8df975fc";
      fsType = "btrfs";
      options = btrfsCommon;
    };

    "/boot" = {
      device = "/dev/disk/by-uuid/0E32-3071";
      fsType = "vfat";
      options = [
        "fmask=0077"
        "dmask=0077"
      ];
    };
  };

  swapDevices = [
    {
      device = "/swap/swapfile";
      options = [
        "discard=async"
        "pri=80"
      ];
    }
  ];

  nixpkgs.hostPlatform = lib.mkDefault "x86_64-linux";
  hardware.cpu.intel.updateMicrocode = lib.mkDefault config.hardware.enableRedistributableFirmware;
}
